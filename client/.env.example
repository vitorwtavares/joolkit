VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: only set when the API is hosted on a different origin.
# Leave unset for the standard Vercel deployment, where the API is served from /api.
# VITE_API_URL=http://localhost:3001

# Optional: set to "landing" only on the marketing site's Vercel project.
# Renders the landing page at "/" and points its sign-in/sign-up links at app.joolkit.com.
# VITE_SITE=landing
