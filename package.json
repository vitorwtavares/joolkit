{
  "name": "joolkit",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.6",
  "engines": {
    "node": "24.x",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,md}": "prettier --write",
    "client/src/**/*.{ts,tsx}": "pnpm --filter client exec eslint --fix"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.16"
  }
}
